---
interface Props {
  id: string;
  name: string;
  specialty: string;
  description: string;
  quote: string;
  photo: string;
  instagramUrl: string;
  whatsappUrl: string;
}

const { id, name, specialty, description, quote, photo, instagramUrl, whatsappUrl } = Astro.props;
---

<div
  id={`modal-${id}`}
  class="fixed inset-0 z-[100] hidden items-center justify-center p-4"
  role="dialog"
  aria-modal="true"
  aria-label={`Perfil de ${name}`}
>
  <!-- Backdrop -->
  <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" data-modal-backdrop></div>

  <!-- Card -->
  <div class="relative max-w-5xl w-full bg-surface-container overflow-hidden shadow-2xl flex flex-col md:flex-row z-10 max-h-[90vh] overflow-y-auto">

    <!-- Close button -->
    <button
      class="absolute top-6 right-6 z-20 text-on-surface/40 hover:text-primary transition-colors"
      data-modal-close
      aria-label="Cerrar"
    >
      <span class="material-symbols-outlined text-3xl">close</span>
    </button>

    <!-- Left: Photo -->
    <div class="w-full md:w-1/2 h-[300px] md:h-auto relative overflow-hidden shrink-0">
      <img
        alt={`Coach ${name}`}
        class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700"
        src={photo}
      />
      <div class="absolute inset-0 bg-gradient-to-t from-surface-container via-transparent to-transparent md:bg-gradient-to-r md:from-transparent md:to-surface-container"></div>
    </div>

    <!-- Right: Details -->
    <div class="w-full md:w-1/2 p-8 md:p-12 flex flex-col justify-center">
      <h1 class="text-5xl md:text-6xl font-headline font-black italic uppercase tracking-tighter text-on-surface mb-2 leading-none">
        {name}
      </h1>
      <h2 class="text-xl md:text-2xl font-body font-light text-primary-fixed mb-8 tracking-wide">
        {specialty}
      </h2>
      <div class="space-y-6 mb-10">
        <p class="text-on-surface/80 text-lg leading-relaxed font-light">
          {description}
        </p>
        <p class="text-on-surface/60 text-sm italic border-l-2 border-primary-container pl-4">
          {quote}
        </p>
      </div>
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          class="kinetic-gradient flex-1 py-4 px-6 rounded-xl text-center font-headline font-bold text-on-primary-container text-sm uppercase tracking-widest hover:brightness-110 active:scale-[0.98] transition-all flex items-center justify-center gap-2"
          href={instagramUrl}
          target="_blank"
          rel="noopener noreferrer"
        >
          <span class="material-symbols-outlined text-lg">share</span>
          INSTAGRAM
        </a>
        <a
          class="border border-outline-variant/30 flex-1 py-4 px-6 rounded-xl text-center font-headline font-bold text-on-surface text-sm uppercase tracking-widest hover:bg-surface-container-high active:scale-[0.98] transition-all flex items-center justify-center gap-2"
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
        >
          <span class="material-symbols-outlined text-lg">chat</span>
          WHATSAPP
        </a>
      </div>
    </div>
  </div>
</div>
