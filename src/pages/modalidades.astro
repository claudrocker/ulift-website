---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Modalidades - URBANLIFT">
  <main class="pt-24 min-h-screen">
    <!-- Hero Header with Large Watermark -->
    <header class="px-8 mb-16 max-w-7xl mx-auto relative overflow-hidden">
      <div class="absolute -top-10 -left-10 text-[12rem] font-black text-white/[0.03] pointer-events-none font-headline tracking-tighter leading-none select-none">URBANLIFT</div>
      <h1 class="font-headline text-7xl md:text-9xl font-extrabold uppercase tracking-tighter leading-none mb-4 relative z-10">
        <span class="text-on-background">nuestras</span><br/>
        <span class="text-brand-orange italic">modalidades</span>
      </h1>
      <p class="font-body text-xl text-on-surface-variant max-w-2xl relative z-10">
        Elige la modalidad que más se adapte a ti
      </p>
    </header>

    <!-- Category Grid: 2x2 Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-0 border-t border-white/5">
      <!-- Category 1: Clases grupales de calistenia -->
      <section class="relative group overflow-hidden border-b border-r border-white/5 bg-surface min-h-[600px] flex flex-col">
        <div class="absolute inset-0 z-0">
          <img alt="Calistenia" class="w-full h-full object-cover grayscale opacity-40 transition-transform duration-700 group-hover:scale-105" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCtQRBJfoZGMoc5VWznNmbrxSGU8CHZBhqajGXGyIjr0PibT6182qgGoqfqEe6CH0bLaqfPukmYKHXUBtcXDdY4suwklU5Bj6jWOunF8rZwmxktmpqzk4STmIpJYjomVNLj8kl0HF0zbz0VwFzJddsryXDyLw0QPESo4DwCmjMXc1c6tjgm3K2qhFAMtH40SpDndhA7zE5jRjH7lHkiKAwTB32-4EoTPVaBA1C-ttcdMAbs7G1vmpw_PuQLkfFW8Y62Yb20i7lO9mQ" />
          <div class="absolute inset-0 bg-gradient-to-t from-surface via-surface/80 to-transparent"></div>
        </div>
        <div class="relative z-10 p-12 mt-auto">
          <h2 class="font-headline text-4xl font-bold uppercase tracking-tighter mb-4 text-white">1. Clases grupales de calistenia</h2>
          <p class="font-body text-on-surface-variant mb-8 max-w-md text-lg">Únete a nuestras clases grupales de calistenia mulnivel. En dónde aprenderas todo lo necesario para dominar tu cuerpo.</p>
          <div class="grid grid-cols-2 gap-8">
            <div>
              <h3 class="font-headline text-xs font-bold uppercase tracking-widest text-brand-orange mb-4">COACHES</h3>
              <div class="flex gap-4">
                <div class="text-center">
                  <img alt="Thomas" class="w-12 h-12 rounded-full border border-brand-orange mb-2" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAlaEozdDxFaMRVtKFQXsJzZhkV_2ZF5QBDzezpnT_wmRK1oESInV_JIf3oIM_oohuDR5s93rax7jv-h_R_uOF3bkVdDo6GjwN1MiBtiNciQMV2lAJNikpeI6CJd_qI4YdhDYZfTyOaogy6M2sOJgUQS4zFrBytE3lCm3savYV2YZKcijWI3BgXPngQaawsqAwnNv_s1g0taDWEY9wpZGm8guEbNeDNjdMvrGYHS1X4Xuo606N7hstbLFGrkdZVkEMcgtAZrZmXqc0" />
                  <span class="text-[10px] font-bold uppercase tracking-tighter">Thomas</span>
                </div>
                <div class="text-center">
                  <img alt="Allison" class="w-12 h-12 rounded-full border border-brand-orange mb-2" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCaWpGZH6S-OWI2bQlpPwKaYrNyzsCFO3QIxekh6_2lklivvOBOYGs2pQ6RrTXw53F7OcLs2Bw2ZZnheWSZInLK7E-Uad1I02bThNqpeiIpqBjvy4rlzH3Nqya_on4cFtYYA2r6QJ7SL0Jj3uMFQ7XHKmqfk2MLapUOdxiMf_Ywd68vQpl39BsnIjyDu6FvcxJl06kBheGfP36fk0Muq1oqn-K91M_XA2VfbHSpiMgm-mIWKo_fgP1-JrjzRNkj_V55BUHA3eb4iYc" />
                  <span class="text-[10px] font-bold uppercase tracking-tighter">Allison</span>
                </div>
              </div>
            </div>
          </div>
          <button class="mt-8 border-b-2 border-brand-orange text-brand-orange font-headline font-bold uppercase tracking-widest pb-1 hover:text-white hover:border-white transition-all text-sm">Revisa nuestros horarios y valores</button>
        </div>
      </section>

      <!-- Category 2: Clases semi-personalizadas -->
      <section class="relative group overflow-hidden border-b border-white/5 bg-surface-container-low min-h-[600px] flex flex-col">
        <div class="absolute inset-0 z-0">
          <img alt="Clases exclusivas" class="w-full h-full object-cover grayscale opacity-20 transition-transform duration-700 group-hover:scale-105" src="https://lh3.googleusercontent.com/aida-public/AB6AXuD2Vz5zasWSg958cRTtTQb2GXAMm2Cy_W1fmhCfS_V6bU6-kgiaU8QtpvdtQb739SkfSXMe-OP59b34Vk0AcOgFv8irrJfZXo37gq1S0mIr9xlJIM7Rjrc7-AJF4rU-NpcKO8Tb53dAHtCoj9f2mERgyuijbLRBuEDeOP3Qkw52HOvQr5ALs0UcCJ-FlsRKCmhvkmOz0g1hr7oeXdP0po5vDEHvSGH3j1WbdGcjlh76KaEdv4NyIKL43sPYUJVUGIuwJPZIx1mbD6Q" />
          <div class="absolute inset-0 bg-gradient-to-t from-surface via-surface/80 to-transparent"></div>
        </div>
        <div class="relative z-10 p-12 mt-auto">
          <h2 class="font-headline text-4xl font-bold uppercase tracking-tighter mb-4 text-white">2. Clases semi-personalizadas</h2>
          <p class="font-body text-on-surface-variant mb-8 max-w-md text-lg">Entrena 1:1 junto a tu coach o en un grupo reducido (máx 4 personas).</p>
          <div class="space-y-4 mb-8">
            <div class="flex items-start gap-4 p-4 bg-white/5 border-l-2 border-brand-orange">
              <span class="material-symbols-outlined text-brand-orange">groups</span>
              <div>
                <div class="font-headline font-bold text-sm uppercase">Atención Especializada</div>
                <div class="text-xs text-on-surface-variant">Corrección técnica al detalle en cada repetición.</div>
              </div>
            </div>
            <div class="flex items-start gap-4 p-4 bg-white/5 border-l-2 border-outline-variant">
              <span class="material-symbols-outlined text-brand-orange">timer</span>
              <div>
                <div class="font-headline font-bold text-sm uppercase">Optimización del Tiempo</div>
                <div class="text-xs text-on-surface-variant">Sesiones dinámicas adaptadas a tu ritmo.</div>
              </div>
            </div>
          </div>
          <button class="kinetic-gradient w-full py-4 text-white font-headline font-bold uppercase tracking-widest rounded-xl hover:shadow-[0_0_20px_rgba(204,100,0,0.4)] transition-all">RESERVAR CUPO</button>
        </div>
      </section>

      <!-- Category 3: Asesorías Online -->
      <section class="relative group overflow-hidden border-r border-white/5 bg-surface-container-high min-h-[600px] flex flex-col">
        <div class="absolute inset-0 z-0">
          <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')] opacity-10"></div>
          <div class="absolute inset-0 bg-gradient-to-t from-surface via-surface/60 to-transparent"></div>
        </div>
        <div class="relative z-10 p-12 mt-auto">
          <h2 class="font-headline text-4xl font-bold uppercase tracking-tighter mb-4 text-white">3. Asesorías Online</h2>
          <p class="font-body text-on-surface-variant mb-8 max-w-md text-lg">Entrena en nuestro gimnasio o cualquier parte del mundo con la guía profesional de nuestros entrenadores.</p>
          <div class="grid grid-cols-1 gap-6 mb-8">
            <div class="flex gap-4 items-center border-b border-white/10 pb-4">
              <div class="w-12 h-12 rounded-lg bg-brand-orange/10 flex items-center justify-center">
                <span class="material-symbols-outlined text-brand-orange">language</span>
              </div>
              <div>
                <div class="font-headline font-bold uppercase text-sm">SIN FRONTERAS</div>
                <div class="text-xs text-on-surface-variant">Planificación 100% remota y personalizada.</div>
              </div>
            </div>
            <div class="flex gap-4 items-center border-b border-white/10 pb-4">
              <div class="w-12 h-12 rounded-lg bg-brand-orange/10 flex items-center justify-center">
                <span class="material-symbols-outlined text-brand-orange">verified</span>
              </div>
              <div>
                <div class="font-headline font-bold uppercase text-sm">GARANTÍA DE RESULTADOS</div>
                <div class="text-xs text-on-surface-variant">Feedback semanal y ajustes de programa.</div>
              </div>
            </div>
          </div>
          <button class="border-2 border-brand-orange w-full py-4 text-white font-headline font-bold uppercase tracking-widest rounded-xl hover:bg-brand-orange transition-all">SABER MÁS</button>
        </div>
      </section>

      <!-- Category 4: Professional Team -->
      <section class="relative group overflow-hidden bg-surface-container-lowest min-h-[600px] flex flex-col p-12">
        <div class="absolute inset-0 z-0">
          <img alt="Fondo industrial" class="w-full h-full object-cover grayscale opacity-10" src="https://lh3.googleusercontent.com/aida-public/AB6AXuD2Vz5zasWSg958cRTtTQb2GXAMm2Cy_W1fmhCfS_V6bU6-kgiaU8QtpvdtQb739SkfSXMe-OP59b34Vk0AcOgFv8irrJfZXo37gq1S0mIr9xlJIM7Rjrc7-AJF4rU-NpcKO8Tb53dAHtCoj9f2mERgyuijbLRBuEDeOP3Qkw52HOvQr5ALs0UcCJ-FlsRKCmhvkmOz0g1hr7oeXdP0po5vDEHvSGH3j1WbdGcjlh76KaEdv4NyIKL43sPYUJVUGIuwJPZIx1mbD6Q" />
          <div class="absolute inset-0 bg-gradient-to-b from-surface via-transparent to-surface"></div>
        </div>
        <div class="relative z-10 w-full flex flex-col h-full">
          <header class="mb-12">
            <h2 class="font-headline text-4xl font-bold uppercase tracking-tighter text-white">CONOCE A NUESTROS<br><span class="text-brand-orange">PROFESIONALES</span></h2>
            <p class="font-body text-on-surface-variant mt-2 text-sm uppercase tracking-widest">El equipo de élite detrás de tu transformación</p>
          </header>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-6 flex-grow">
            <!-- Coach 1 -->
            <div class="group/coach relative overflow-hidden bg-surface-container-high border border-white/10 rounded-lg p-4 flex flex-col items-center text-center transition-all hover:border-brand-orange/50">
              <div class="w-24 h-24 mb-4 rounded-full bg-surface-container-highest border-2 border-brand-orange/20 overflow-hidden flex items-center justify-center group-hover/coach:border-brand-orange transition-colors">
                <span class="material-symbols-outlined text-white/20 text-4xl">person</span>
              </div>
              <div class="font-headline font-bold text-white uppercase tracking-tighter group-hover/coach:text-brand-orange transition-colors">Allison Bassa</div>
              <div class="text-[10px] text-on-surface-variant font-bold uppercase mt-1 tracking-widest">Calistenia y stret lifting</div>
            </div>
            <!-- Coach 2 -->
            <div class="group/coach relative overflow-hidden bg-surface-container-high border border-white/10 rounded-lg p-4 flex flex-col items-center text-center transition-all hover:border-brand-orange/50">
              <div class="w-24 h-24 mb-4 rounded-full bg-surface-container-highest border-2 border-brand-orange/20 overflow-hidden flex items-center justify-center group-hover/coach:border-brand-orange transition-colors">
                <span class="material-symbols-outlined text-white/20 text-4xl">person</span>
              </div>
              <div class="font-headline font-bold text-white uppercase tracking-tighter group-hover/coach:text-brand-orange transition-colors">Thomas Cabezas</div>
              <div class="text-[10px] text-on-surface-variant font-bold uppercase mt-1 tracking-widest">Calistenia y stret lifting</div>
            </div>
            <!-- Coach 3 -->
            <div class="group/coach relative overflow-hidden bg-surface-container-high border border-white/10 rounded-lg p-4 flex flex-col items-center text-center transition-all hover:border-brand-orange/50">
              <div class="w-24 h-24 mb-4 rounded-full bg-surface-container-highest border-2 border-brand-orange/20 overflow-hidden flex items-center justify-center group-hover/coach:border-brand-orange transition-colors">
                <span class="material-symbols-outlined text-white/20 text-4xl">person</span>
              </div>
              <div class="font-headline font-bold text-white uppercase tracking-tighter group-hover/coach:text-brand-orange transition-colors">Fabian Lopez</div>
              <div class="text-[10px] text-on-surface-variant font-bold uppercase mt-1 tracking-widest">Power lifting</div>
            </div>
            <!-- View More / Stats -->
            <div class="relative overflow-hidden bg-brand-orange/5 border border-brand-orange/20 rounded-lg p-4 flex flex-col items-center justify-center text-center">
              <div class="text-3xl font-headline font-extrabold text-brand-orange">+10</div>
              <div class="text-[10px] text-white font-bold uppercase tracking-widest mt-1">Años de exp</div>
            </div>
          </div>
        </div>
      </section>
    </div>
  </main>
</Layout>
